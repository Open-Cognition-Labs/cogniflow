# Copy to .env (gitignored). The seeded Acme hero demo works with NONE of these set - it is
# key-free (audit endpoints, no LLM/embeddings). Real generation (/api/answer) and real-document
# retrieval need the provider keys below.

# --- security ---
# Bearer token the compose provisions and the web build bakes in. It is a LOCAL DEMO token -
# change it (and keep it out of git) for anything shared.
COGNIFLOW_DEMO_TOKEN=cogniflow-demo-token

# --- providers (optional) ---
# LLM for generation (/api/answer) and prose fact-extraction. Fail-loud: /answer without a key
# raises rather than guessing.
COGNIFLOW_LLM_API_KEY=
COGNIFLOW_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
COGNIFLOW_LLM_MODEL=minimaxai/minimax-m3

# Embedder for SEMANTIC retrieval. Set -> bge-m3 (semantic). Unset -> the hash embedder, which
# is meaning-blind and WARNS loudly (see Quickstart: bge-m3-local is the key-free semantic path).
COGNIFLOW_EMBEDDER_API_KEY=

# --- optional tuning ---
# COGNIFLOW_RATE_LIMIT_PER_MIN=30 # per-token/IP limit on LLM/embedder endpoints
# COGNIFLOW_MAX_UPLOAD_BYTES=10485760 # upload cap (10 MB)
# COGNIFLOW_OVERFETCH_FACTOR=10 # retrieval over-fetch depth (raise if saturated)
